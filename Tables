-- Country Table
CREATE TABLE Country (
    CountryID INT PRIMARY KEY,
    CountryName NVARCHAR(50)
);

-- States Table
CREATE TABLE States (
    StateID INT PRIMARY KEY,
    StateName NVARCHAR(50)
);

-- Customer Table
CREATE TABLE Customer (
    CustomerCode INT PRIMARY KEY,
    CustomerName NVARCHAR(100),
    CustomerAmount NVARCHAR(100),
    SlaesDate DATE
);

-- Product Table
CREATE TABLE Product (
    ProductID INT PRIMARY KEY,
    ProductName NVARCHAR(100)
);

-- SalesPerson Table
CREATE TABLE SalesPerson (
    PersonID INT PRIMARY KEY,
    PersonName NVARCHAR(100)
);

-- FactCustomer Table (Fact table for BI)
CREATE TABLE FactCustomer (
    FactID INT PRIMARY KEY,
    CustomerID INT FOREIGN KEY REFERENCES Customer(CustomerID),
    ProductID INT FOREIGN KEY REFERENCES Product(ProductID),
    SalesPersonID INT FOREIGN KEY REFERENCES SalesPerson(SalesPersonID),
    Quantity INT,
    SaleDate DATE
);
